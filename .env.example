# Garmin Connect 认证信息
GARMIN_EMAIL=your_email@example.com
GARMIN_PASSWORD=your_password_here
GARMIN_IS_CN=true

# 可选：网页登录 connect.garmin.cn 正常、密码 API 登录失败时使用
# 从浏览器 Cookie 复制 JWT_WEB；写入类接口如训练/体重可能还需要 CSRF。
GARMIN_JWT_WEB=
GARMIN_CSRF_TOKEN=

# REST API 服务密钥（自行生成一个随机字符串）
GARMIN_API_KEY=change-me-to-a-random-string
